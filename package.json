{
  "name": "silicone-mold-app",
  "version": "0.0.0",
  "private": true,
  "description": "Desktop app for generating 3D-printable silicone mold parts from STL masters.",
  "author": "Tiberiu Gache <gache.tiberiu@gmail.com>",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "dist/main/index.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && electron-builder",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:visual": "playwright test --project=visual",
    "format": "prettier --write ."
  },
  "dependencies": {
    "three": "^0.169.0",
    "three-mesh-bvh": "^0.9.9",
    "manifold-3d": "^3.4.1",
    "i18next": "^25.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "@types/three": "^0.169.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.0.0",
    "electron-updater": "^6.3.0",
    "eslint": "^9.16.0",
    "prettier": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.29.0",
    "vitest": "^3.0.0"
  }
}
