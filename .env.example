# Copy to .env and fill in. Never commit .env.
# Code signing (Electron build — required only for signed builds)
WIN_CSC_LINK=
WIN_CSC_KEY_PASSWORD=
# OR Azure Trusted Signing
AZURE_TRUSTED_SIGNING_ENDPOINT=
AZURE_TRUSTED_SIGNING_ACCOUNT=
AZURE_TRUSTED_SIGNING_CERT_PROFILE=

# electron-updater publish target (GitHub Releases)
GH_TOKEN=

# Sentry / telemetry (post-v1)
# SENTRY_DSN=
